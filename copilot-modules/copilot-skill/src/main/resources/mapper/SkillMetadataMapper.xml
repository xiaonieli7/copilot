<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.alibaba.cloud.ai.copilot.skill.mapper.SkillMetadataMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.alibaba.cloud.ai.copilot.skill.domain.entity.SkillMetadata">
        <id column="id" property="id" />
        <result column="skill_name" property="skillName" />
        <result column="display_name" property="displayName" />
        <result column="description" property="description" />
        <result column="scope" property="scope" />
        <result column="enabled" property="enabled" />
        <result column="category" property="category" />
        <result column="version" property="version" />
        <result column="author" property="author" />
        <result column="tags" property="tags" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler" />
        <result column="dependencies" property="dependencies" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler" />
        <result column="file_path" property="filePath" />
        <result column="user_id" property="userId" />
        <result column="created_time" property="createdTime" />
        <result column="updated_time" property="updatedTime" />
    </resultMap>

</mapper>
